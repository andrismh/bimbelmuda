<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — Bimbel Muda</title>
    <link rel="icon" type="image/png" href="/assets/img/bimbelmuda_logo.png" />
    <script src="/vendor/plotly.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: "Georgia", "Times New Roman", serif;
        background: #f6f6f3;
        color: #1a1a1a;
        line-height: 1.7;
        padding: 2rem 1rem 4rem;
      }

      .page-wrap {
        max-width: 740px;
        margin: 0 auto;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: "Arial", sans-serif;
        font-size: 0.8rem;
        color: #777;
        text-decoration: none;
        margin-bottom: 2.5rem;
        letter-spacing: 0.02em;
        transition: color 0.15s;
      }
      .back-link:hover { color: #222; }

      /* ── Header ── */
      .post-header { margin-bottom: 2.5rem; }

      .post-title {
        font-family: "Arial", sans-serif;
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.25;
        color: #111;
        margin-bottom: 0.75rem;
      }

      @media (max-width: 640px) {
        body { padding: 1.25rem 0.75rem 3rem; }
        .post-title { font-size: 1.5rem; }
        .prose h1 { font-size: 1.35rem; }
        .prose h2 { font-size: 1.15rem; }
        .prose h3 { font-size: 1rem; }
        .prose { font-size: 0.97rem; }
        .prose .shiki { font-size: 0.8rem; padding: 1em; }
      }

      .post-meta {
        font-family: "Arial", sans-serif;
        font-size: 0.78rem;
        color: #888;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
      }

      .tag {
        background: #e8e8e3;
        color: #555;
        border-radius: 4px;
        padding: 0.15em 0.55em;
        font-size: 0.72rem;
        letter-spacing: 0.03em;
      }

      /* ── Prose ── */
      .prose { font-size: 1.025rem; }

      .prose p { margin: 1.15em 0; }

      .prose h1, .prose h2, .prose h3, .prose h4 {
        font-family: "Arial", sans-serif;
        font-weight: 700;
        line-height: 1.3;
        color: #111;
        margin: 2em 0 0.6em;
      }
      .prose h1 { font-size: 1.7rem; }
      .prose h2 { font-size: 1.35rem; border-bottom: 1px solid #e0e0da; padding-bottom: 0.3em; }
      .prose h3 { font-size: 1.1rem; }

      .prose ul, .prose ol { padding-left: 1.5em; margin: 1em 0; }
      .prose li { margin: 0.35em 0; }

      .prose a { color: #0070f3; text-decoration: underline; }
      .prose a:hover { color: #0050c0; }

      .prose blockquote {
        border-left: 3px solid #d0d0ca;
        margin: 1.5em 0;
        padding: 0.5em 1.25em;
        color: #555;
        font-style: italic;
        background: #f0f0ec;
        border-radius: 0 6px 6px 0;
      }

      .prose hr { border: none; border-top: 1px solid #e0e0da; margin: 2em 0; }

      /* inline code */
      .prose code {
        font-family: "SFMono-Regular", "Consolas", "Menlo", monospace;
        font-size: 0.875em;
        background: #eeeee8;
        border-radius: 4px;
        padding: 0.15em 0.4em;
        color: #c7254e;
      }

      /* shiki block overrides */
      .prose .shiki {
        border-radius: 10px;
        margin: 1.5em 0;
        padding: 1.25em 1.5em;
        overflow-x: auto;
        font-size: 0.88rem;
        line-height: 1.6;
        position: relative;
      }
      .prose .shiki code { background: none; padding: 0; color: inherit; font-size: inherit; border-radius: 0; }

      /* ── Output block ── */
      .code-output {
        margin: -0.75em 0 1.5em;
        border-radius: 0 0 10px 10px;
        background: #0d1117;
        overflow-x: auto;
      }
      .code-output-label {
        display: block;
        font-family: "Arial", sans-serif;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #4a9a4a;
        padding: 0.55em 1.25em 0;
      }
      .code-output pre {
        font-family: "SFMono-Regular", "Consolas", "Menlo", monospace;
        font-size: 0.84rem;
        color: #8cc88c;
        padding: 0.6em 1.25em 1em;
        white-space: pre-wrap;
        word-break: break-all;
      }

      /* ── Chart block ── */
      .plotly-chart {
        margin: 1.75em 0;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #e0e0da;
        min-height: 60px;
        position: relative;
      }
      .plotly-chart[data-loading]::before {
        content: "Loading chart…";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Arial", sans-serif;
        font-size: 0.8rem;
        color: #aaa;
      }

      /* ── Footer meta ── */
      .post-footer {
        font-family: "Arial", sans-serif;
        font-size: 0.76rem;
        color: #aaa;
        margin-top: 3.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e0e0da;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
    </style>
  </head>
  <body>
    <div class="page-wrap">
      <a href="/generated/index.html" class="back-link">← All Posts</a>

      <header class="post-header">
        <h1 class="post-title"><%= title %></h1>
        <div class="post-meta">
          <span><%= new Date(createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) %></span>
          <% if (post.tags && post.tags.length) { %>
            <% post.tags.forEach(function(tag) { %><span class="tag"><%= tag %></span><% }) %>
          <% } %>
        </div>
      </header>

      <article class="prose">
        <%- renderedContent %>
      </article>

      <footer class="post-footer">
        <span>Created: <%= new Date(createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) %></span>
        <span>Updated: <%= new Date(updatedAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" }) %></span>
      </footer>
    </div>

    <script>
      document.querySelectorAll(".plotly-chart[data-chart]").forEach(function (el) {
        el.setAttribute("data-loading", "");
        try {
          var spec = JSON.parse(decodeURIComponent(el.dataset.chart));
          var layout = Object.assign({ height: 400, margin: { t: 40, r: 20, b: 40, l: 50 }, paper_bgcolor: "#fff", plot_bgcolor: "#fff" }, spec.layout || {});
          Plotly.newPlot(el, spec.data || [], layout, { responsive: true, displayModeBar: false });
        } catch (e) {
          el.textContent = "Chart failed to render.";
          console.error("[plotly]", e);
        } finally {
          el.removeAttribute("data-loading");
        }
      });
    </script>
  </body>
</html>
